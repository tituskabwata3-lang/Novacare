# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# ── AI ──────────────────────────────────────────────────────────────────────
# Your Anthropic API key — get it from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── ADMIN ───────────────────────────────────────────────────────────────────
# A secret string you make up — used to protect the admin panel
ADMIN_SECRET=your_admin_secret_here

# ── TWILIO (Voice Calls) ─────────────────────────────────────────────────────
# Get these from twilio.com/console after creating an account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Fallback human agent number if a client has none configured
# Format: +[country code][number], e.g. +260971234567
DEFAULT_HUMAN_AGENT_NUMBER=+260XXXXXXXXX

# ── VERCEL ──────────────────────────────────────────────────────────────────
# Vercel sets this automatically — you don't need to add it manually
# VERCEL_URL=your-app.vercel.app
